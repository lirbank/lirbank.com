---
import type { HTMLAttributes } from "astro/types";

// Gutter padding sits outside the max-width so the content box is a true
// 980px at the wide breakpoint.
type Props = HTMLAttributes<"div">;

const { class: className, ...props } = Astro.props;
---

<div {...props} class:list={["px-gutter", className]}>
  <div class="max-w-measure wide:max-w-site mx-auto">
    <slot />
  </div>
</div>
