---
import { getCollection, getEntry, render } from "astro:content";
import Article from "../layouts/article.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, "") },
  }));
}

const { slug } = Astro.params;
const entry = await getEntry("blog", slug!);
if (!entry) return Astro.redirect("/404");

const { Content } = await render(entry);

const title = entry.data.title;
const description = entry.data.description;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

function formatDate(dateStr: string | undefined) {
  if (!dateStr) return null;
  return new Date(dateStr + "T00:00:00").toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Article
  title={title}
  description={description}
  date={entry.data.published}
  updated={entry.data.updated}
  slug={slug}
  canonicalUrl={canonicalUrl}
>
  <div class="border-b border-stone-300/50 px-5 pb-5 sm:px-20">
    <article
      class="prose prose-stone sm:prose-lg prose-a:text-cyan-600 mx-auto"
    >
      <header class="mb-6">
        <h1 class="mb-2">{title}</h1>
        <div class="space-y-1 text-sm text-stone-500">
          <time datetime={entry.data.published}>
            {formatDate(entry.data.published)}
          </time>
          {
            entry.data.updated && (
              <span class="block">
                Updated {formatDate(entry.data.updated)}
              </span>
            )
          }
        </div>
      </header>
      <Content />
    </article>
  </div>
</Article>
