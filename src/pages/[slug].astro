---
import { getCollection, getEntry, render } from "astro:content";
import Layout from "../layouts/layout.astro";
import metadata from "../../metadata.json";
import { Image } from "astro:assets";
import heroImage from "../assets/brand/mikael-lirbank.jpg";
import { Icon } from "astro-icon/components";
import { contact } from "../data/contact";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((article) => ({
    params: { slug: article.id.replace(/\.md$/, "") },
  }));
}

const { slug } = Astro.params;
const entry = await getEntry("articles", slug);
if (!entry) return Astro.redirect("/404");

const { Content } = await render(entry);

function formatDate(dateStr: string | undefined) {
  if (!dateStr) return null;
  return new Date(dateStr + "T00:00:00").toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    // day: "numeric",
  });
}
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  ogImage={`/og/${slug}.png`}
  article={{
    date: entry.data.published,
    updated: entry.data.updated,
    author: metadata.name,
  }}
>
  <section>
    <article class="prose prose-stone sm:prose-lg prose-a:text-cyan-600">
      <header class="mb-10 flex flex-col gap-1">
        <div class="text-base">
          {entry.data.author} — <time datetime={entry.data.published}
            >{formatDate(entry.data.published)}</time
          >{
            entry.data.updated && (
              <> (updated {formatDate(entry.data.updated)})</>
            )
          }
        </div>
        <div class="text-sm text-stone-600 italic">
          Independent consultant. I build robust, high-quality software systems,
          <a href="/#contact" class="text-nowrap">get in touch</a>.
        </div>
      </header>
      <Content />
    </article>

    <!-- <hr class="my-14 border-stone-200" /> -->

    <!-- Author card -->
    <div class="-mx-4 mt-15 p-4 sm:rounded-md sm:bg-stone-50 sm:shadow">
      <blockquote class="border-stone-300 italic">
        <p>
          I'm Mikael, an independent consultant based in the SF Bay Area. I
          build robust, high-quality software systems—<a
            href="/#contact"
            class="text-stone-800 underline hover:text-stone-900"
            >get in touch</a
          >.
        </p>
      </blockquote>
      <div class="mt-4 flex items-center gap-2">
        <a href="/#contact" class="shrink-0">
          <Image
            class="size-12 rounded-full object-cover shadow"
            src={heroImage}
            alt="Mikael Lirbank"
            width={96}
            height={96}
            quality={80}
            loading="lazy"
          />
        </a>
        <div class="flex flex-col">
          <strong class="text-lg">Mikael Lirbank</strong>
          <div class="flex gap-1">
            {
              contact.map(({ href, icon, label }) => (
                <a href={href} aria-label={label} title={label}>
                  <Icon name={icon} class="size-5" />
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
