---
import { getCollection, getEntry, render } from "astro:content";
import Layout from "../layouts/layout.astro";
import Container from "../components/container.astro";
import Letterhead from "../components/letterhead.astro";
import ArticleRow from "../components/article-row.astro";
import ContactLinks from "../components/contact-links.astro";
import { homepage } from "../data/homepage";
import { Image } from "astro:assets";
import heroImage from "../assets/brand/mikael-lirbank.jpg";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((article) => ({
    params: { slug: article.id },
  }));
}

const { slug } = Astro.params;
const entry = await getEntry("articles", slug);
if (!entry) return Astro.redirect("/404");

const { Content } = await render(entry);

// Each h2 opens a numbered section ("01 / 10"); the total feeds the CSS
// counter via the inline style below.
const sectionCount = (entry.rendered?.html?.match(/<h2/g) ?? []).length;

const moreArticles = (await getCollection("articles"))
  .filter((article) => article.id !== slug)
  .sort(
    (a, b) =>
      new Date(b.data.published).getTime() -
      new Date(a.data.published).getTime(),
  );

const monthYear = new Date(
  entry.data.published + "T00:00:00",
).toLocaleDateString("en-US", { month: "long", year: "numeric" });
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  ogImage={`/og/${slug}.png`}
  article={{
    date: entry.data.published,
    updated: entry.data.updated,
    author: entry.data.author,
  }}
>
  <Container>
    <div class="py-section-pad">
      <div
        class="wide:grid wide:grid-cols-[var(--label-col)_1fr] wide:gap-x-(--col-gap)"
      >
        <div class="mb-stack-gap wide:mb-0">
          <Letterhead />
        </div>
        <article class="max-w-measure min-w-0">
          <div class="kicker flex flex-wrap items-center gap-x-2.5 gap-y-2">
            <time datetime={entry.data.published}>{monthYear}</time>
            <span>·</span>
            <a href={`/${slug}.md`} class="link">View as Markdown</a>
          </div>
          <div
            class="article-prose"
            style={`counter-reset: section 0 section-total ${sectionCount}`}
          >
            <Content />
          </div>
        </article>
      </div>

      <!-- More articles -->
      <aside
        class="border-hairline mt-stack-gap pt-stack-gap wide:grid wide:grid-cols-[var(--label-col)_1fr] wide:gap-x-(--col-gap) border-t"
      >
        <div class="kicker wide:mb-0 wide:pt-1 mb-4">More articles</div>
        <div class="max-w-measure grid min-w-0 gap-9">
          {moreArticles.map((article) => <ArticleRow article={article} />)}
        </div>
      </aside>

      <!-- Author card -->
      <div
        class="border-hairline mt-stack-gap pt-stack-gap wide:grid wide:grid-cols-[var(--label-col)_1fr] wide:gap-x-(--col-gap) border-t"
      >
        <div class="kicker wide:mb-0 wide:pt-1 mb-4">Contact</div>
        <div class="max-w-measure min-w-0">
          <div class="flex items-center gap-3.5">
            <Image
              class="size-18 rounded-full object-cover"
              src={heroImage}
              alt="Mikael Lirbank"
              width={144}
              height={144}
              quality={80}
              loading="lazy"
            />
            <div class="text-body text-ink font-semibold">Mikael Lirbank</div>
          </div>
          {
            homepage.pitch.map((paragraph) => (
              <p class="description mt-3 first:mt-4">{paragraph}</p>
            ))
          }
          <div class="mt-4">
            <ContactLinks />
          </div>
        </div>
      </div>
    </div>
  </Container>
</Layout>
