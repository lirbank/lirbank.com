---
import Container from "./container.astro";
import { navLinks } from "../data/nav";
---

<nav data-site-nav class="border-hairline bg-paper sticky top-0 z-10 border-b">
  <Container>
    <div class="flex items-center justify-between md:py-6">
      <a
        href="/"
        class="text-body text-ink hidden shrink-0 border-none font-semibold md:block"
      >
        Mikael Lirbank
      </a>
      <!-- Full bleed while the chip bar scrolls: swallow the gutters so the
           row reaches the screen edges, and give them back as padding inside -->
      <div
        class="text-small text-quote max-md:-mx-gutter max-md:px-gutter flex scrollbar-none gap-5 overflow-x-auto py-3.5 md:gap-6 md:overflow-visible md:py-0"
      >
        {
          navLinks.map(({ label, href }) => (
            <a
              href={href}
              class="hover:text-ink aria-current:text-ink aria-current:border-ink border-b border-transparent pb-0.5 whitespace-nowrap transition-colors"
            >
              {label}
            </a>
          ))
        }
      </div>
    </div>
  </Container>
</nav>

<script>
  // Scrollspy: the section crossing the band below the sticky nav is
  // current. Sections are contiguous, so at most a few intersect at once —
  // the last one in document order wins.
  const nav = document.querySelector("[data-site-nav]");
  const links = [
    ...(nav?.querySelectorAll<HTMLAnchorElement>("a[href*='#']") ?? []),
  ];
  const sections = links
    .map((link) => document.getElementById(new URL(link.href).hash.slice(1)))
    .filter((section) => section !== null);

  const reducedMotion = matchMedia("(prefers-reduced-motion: reduce)");
  let active: HTMLAnchorElement | null = null;

  const visible = new Set<string>();
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) visible.add(entry.target.id);
        else visible.delete(entry.target.id);
      }
      const current = sections.findLast((section) => visible.has(section.id));
      const link = current
        ? (links.find((l) => l.hash === `#${current.id}`) ?? null)
        : null;
      if (link === active) return;

      active?.removeAttribute("aria-current");
      active = link;
      if (link) {
        link.setAttribute("aria-current", "true");
        link.scrollIntoView({
          behavior: reducedMotion.matches ? "auto" : "smooth",
          block: "nearest",
          inline: "nearest",
        });
      }
    },
    // Band: from just below the nav to 40% of the viewport
    { rootMargin: "-80px 0px -60% 0px" },
  );
  sections.forEach((section) => observer.observe(section));
</script>
