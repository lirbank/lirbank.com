---
import { getCollection, getEntry, render } from "astro:content";
import Layout from "../layouts/layout.astro";
import metadata from "../../metadata.json";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((article) => ({
    params: { slug: article.id.replace(/\.md$/, "") },
  }));
}

const { slug } = Astro.params;
const entry = await getEntry("articles", slug!);
if (!entry) return Astro.redirect("/404");

const { Content } = await render(entry);

function formatDate(dateStr: string | undefined) {
  if (!dateStr) return null;
  return new Date(dateStr + "T00:00:00").toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    // day: "numeric",
  });
}
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  ogImage={`/og/${slug}.png`}
  article={{
    date: entry.data.published,
    updated: entry.data.updated,
    author: metadata.name,
  }}
>
  <section>
    <article class="prose prose-stone sm:prose-lg prose-a:text-cyan-600">
      <header class="mb-8 flex flex-col gap-1">
        <div class="text-base">
          {entry.data.author} — <time datetime={entry.data.published}
            >{formatDate(entry.data.published)}</time
          >{
            entry.data.updated && (
              <> (updated {formatDate(entry.data.updated)})</>
            )
          }
        </div>
        <div class="text-sm text-stone-600 italic">
          I build robust, high-quality software systems,
          <a
            href="/#contact"
            class="text-cyan-600 underline underline-offset-2 hover:text-cyan-700"
            >get in touch →</a
          >
        </div>
      </header>
      <Content />
    </article>
  </section>
</Layout>
