{
  "name": "lirbank.com",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "bun test && prettier --check . && astro build && tsc",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "test": "bun test",
    "icons": "bun scripts/generate-icons.ts",
    "clean:soft": "rm -rf node_modules tsconfig.tsbuildinfo .astro dist && bun install",
    "clean:hard": "rm -rf node_modules tsconfig.tsbuildinfo .astro dist bun.lock && bun install",
    "infra:check": "bun infra/check.ts",
    "chrome:dev": "bun build ./chrome/background.ts --outdir ./chrome --watch",
    "chrome:build": "bun build ./chrome/background.ts --outdir ./chrome",
    "generate-types": "wrangler types"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "6.1.8",
    "astro-icon": "^1.1.5",
    "onedollarstats": "^0.0.19",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/fa6-solid": "^1.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bun": "^1.3.12",
    "@types/chrome": "^0.1.40",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "wrangler": "^4.84.1"
  },
  "overrides": {
    "vite": "^7"
  }
}
