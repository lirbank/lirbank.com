---
import { getCollection, getEntry, render } from "astro:content";
import Layout from "../layouts/layout.astro";
import metadata from "../../metadata.json";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, "") },
  }));
}

const { slug } = Astro.params;
const entry = await getEntry("blog", slug!);
if (!entry) return Astro.redirect("/404");

const { Content } = await render(entry);

function formatDate(dateStr: string | undefined) {
  if (!dateStr) return null;
  return new Date(dateStr + "T00:00:00").toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  ogImage={`/og/${slug}.png`}
  article={{
    date: entry.data.published,
    updated: entry.data.updated,
    author: metadata.name,
  }}
>
  <section>
    <article class="prose prose-stone sm:prose-lg prose-a:text-cyan-600">
      <header class="flex flex-col gap-2 pb-2 text-sm text-stone-600">
        <time datetime={entry.data.published}>
          {formatDate(entry.data.published)}
        </time>
        {
          entry.data.updated && (
            <span class="block">Updated {formatDate(entry.data.updated)}</span>
          )
        }
      </header>
      <Content />
    </article>
  </section>
</Layout>
