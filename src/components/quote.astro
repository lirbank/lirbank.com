---
import { render, type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

// Testimonial: italic quote on a hairline rail (no quotation marks),
// then attribution — round avatar, name in ink, role faint.
const avatarImages = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/testimonials/*.jpg",
  { eager: true },
);

interface Props {
  testimonial: CollectionEntry<"testimonials">;
  large?: boolean;
  class?: string;
}

const { testimonial, large = false, class: className } = Astro.props;
const { Content } = await render(testimonial);
const { author } = testimonial.data;
const avatarImage =
  avatarImages[`../assets/testimonials/${author.avatar}`]?.default;
---

<figure class:list={[className]}>
  <blockquote>
    <Content />
  </blockquote>
  <figcaption class="mt-4 flex items-center gap-3">
    <a href={author.url} target="_blank" class="shrink-0 border-none">
      <Image
        class:list={["rounded-full object-cover", large ? "size-9" : "size-8"]}
        src={avatarImage}
        alt={`${author.name}, ${author.title}`}
        width={96}
        height={96}
        quality={80}
        loading="lazy"
      />
    </a>
    <div class="text-small">
      <div class="text-ink font-semibold">{author.name}</div>
      <div class="text-faint">{author.title}</div>
    </div>
  </figcaption>
</figure>
