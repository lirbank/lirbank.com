{
  "name": "lirbank.com",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "bun test && prettier --check . && astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "test": "bun test",
    "icons": "bun scripts/generate-icons.ts",
    "clean:soft": "rm -rf node_modules tsconfig.tsbuildinfo .astro dist && bun install",
    "clean:hard": "rm -rf node_modules tsconfig.tsbuildinfo .astro dist bun.lock && bun install",
    "infra:check": "infra/check.ts",
    "chrome:dev": "bun build ./chrome/background.ts --outdir ./chrome --watch",
    "chrome:build": "bun build ./chrome/background.ts --outdir ./chrome"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.6",
    "onedollarstats": "^0.0.23",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/chrome": "^0.2.2",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "satori": "^0.26.0",
    "sharp": "^0.35.3",
    "typescript": "^6.0.3",
    "wrangler": "^4.107.0"
  }
}
