---
import "../styles/global.css";
import Container from "../components/container.astro";
import { navLinks } from "../data/nav";

interface Props {
  title: string;
  description: string;
  ogImage: string;
  article?: {
    date: string;
    updated: string | null;
    author: string;
  };
}

const { title, description, ogImage, article } = Astro.props;
const year = new Date().getFullYear();
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const canonicalOgImage = new URL(ogImage, Astro.site).href;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/brand/icon.svg" />
    <link rel="apple-touch-icon" href="/brand/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content={article ? "article" : "website"} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={canonicalOgImage} />
    <meta property="og:url" content={canonicalUrl} />
    {
      article && (
        <>
          <meta property="article:author" content={article.author} />
          <meta property="article:published_time" content={article.date} />
          {article.updated && (
            <meta property="article:modified_time" content={article.updated} />
          )}
        </>
      )
    }
    <meta name="twitter:card" content="summary_large_image" />
    <script>
      import { configure } from "onedollarstats";
      configure({ trackLocalhostAs: "www.lirbank.com" });
    </script>
    <script
      is:inline
      src="https://analytics.ahrefs.com/analytics.js"
      data-key="PgGcntXiSuWLTT8vPLDmdg"
      async></script>
    <script>
      // Smooth-scroll only on same-page anchor clicks. Browser-initiated hash
      // scrolls (arriving on /#section from another page, back/forward) stay
      // instant, which a global `scroll-behavior: smooth` can't do.
      document.addEventListener("click", (event) => {
        if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        if (!(event.target instanceof Element)) return;
        const link = event.target.closest("a[href]");
        if (!(link instanceof HTMLAnchorElement)) return;
        const url = new URL(link.href);
        if (!url.hash || url.pathname !== location.pathname) return;
        const target = document.getElementById(url.hash.slice(1));
        if (!target) return;
        event.preventDefault();
        target.scrollIntoView({ behavior: "smooth" });
        history.pushState(null, "", url.hash);
      });
    </script>
  </head>
  <body class="antialiased">
    <slot />
    <footer class="border-hairline border-t">
      <Container>
        <div class="py-10">
          <div class="text-small text-quote flex flex-wrap gap-x-6 gap-y-3">
            {
              navLinks.map(({ label, href }) => (
                <a
                  href={href}
                  class="hover:text-ink border-none transition-colors"
                >
                  {label}
                </a>
              ))
            }
          </div>
          <div class="date mt-9">
            © {year} Mikael Lirbank · Airlab LLC · San Francisco Bay Area
          </div>
        </div>
      </Container>
    </footer>
  </body>
</html>
